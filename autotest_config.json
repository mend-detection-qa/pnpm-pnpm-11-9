{
  "repo_url": "https://github.com/mend-detection-qa/pnpm-pnpm-11-9",
  "package_manager": "pnpm",
  "description": "pnpm 11.9 - lockfile_format, checksum_signing, tree_structure",
  "assertions": [
    {
      "check": "dependency_count",
      "expected": 7,
      "description": "Total resolved dependencies (direct + transitive, prod + dev)"
    },
    {
      "check": "dependency_names",
      "expected": [
        "react",
        "react-dom",
        "@testing-library/react",
        "@testing-library/dom",
        "loose-envify",
        "js-tokens",
        "scheduler"
      ],
      "description": "All 7 packages must appear in the Mend dependency tree"
    },
    {
      "check": "dependency_version",
      "package": "react",
      "expected": "18.3.1",
      "description": "react version must be resolved correctly (not peer-suffix-corrupted)"
    },
    {
      "check": "dependency_version",
      "package": "react-dom",
      "expected": "18.3.1",
      "description": "react-dom version must strip peer suffix e.g. 18.3.1(react@18.3.1) to 18.3.1 (tree_structure regression detector)"
    },
    {
      "check": "dependency_version",
      "package": "@testing-library/react",
      "expected": "14.2.1",
      "description": "dev dep version resolved correctly"
    },
    {
      "check": "dependency_version",
      "package": "scheduler",
      "expected": "0.23.2",
      "description": "transitive dep scheduler version resolved correctly"
    },
    {
      "check": "dependency_version",
      "package": "loose-envify",
      "expected": "1.4.0",
      "description": "transitive dep loose-envify version resolved correctly"
    },
    {
      "check": "dependency_version",
      "package": "js-tokens",
      "expected": "4.0.0",
      "description": "transitive dep js-tokens version resolved correctly"
    },
    {
      "check": "dependency_version",
      "package": "@testing-library/dom",
      "expected": "9.3.4",
      "description": "transitive dep @testing-library/dom version resolved correctly"
    }
  ]
}
