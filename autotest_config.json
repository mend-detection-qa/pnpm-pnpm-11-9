{\n  "repo_url": "https://github.com/mend-detection-qa/pnpm-pnpm-11-9",\n  "package_manager": "pnpm",\n  "description": "pnpm 11.9 \u2014 lockfile_format, checksum_signing, tree_structure",\n  "assertions": [\n    {\n      "check": "dependency_count",\n      "expected": 7,\n      "description": "Total resolved dependencies (direct + transitive, prod + dev)"\n    },\n    {\n      "check": "dependency_names",\n      "expected": [\n        "react",\n        "react-dom",\n        "@testing-library/react",\n        "@testing-library/dom",\n        "loose-envify",\n        "js-tokens",\n        "scheduler"\n      ],\n      "description": "All 7 packages must appear in the Mend dependency tree"\n    },\n    {\n      "check": "dependency_version",\n      "package": "react",\n      "expected": "18.3.1",\n      "description": "react version must be resolved correctly (not peer-suffix-corrupted)"\n    },\n    {\n      "check": "dependency_version",\n      "package": "react-dom",\n      "expected": "18.3.1",\n      "description": "react-dom version must strip peer suffix e.g. '18.3.1(react@18.3.1)' \u2192 '18.3.1' (tree_structure regression detector)"\n    },\n    {\n      "check": "dependency_version",\n      "package": "@testing-library/react",\n      "expected": "14.2.1",\n      "description": "dev dep version resolved correctly"\n    },\n    {\n      "check": "dependency_version",\n      "package": "scheduler",\n      "expected": "0.23.2",\n      "description": "transitive dep scheduler version resolved correctly"\n    },\n    {\n      "check": "dependency_version",\n      "package": "loose-envify",\n      "expected": "1.4.0",\n      "description": "transitive dep loose-envify version resolved correctly"\n    },\n    {\n      "check": "dependency_version",\n      "package": "js-tokens",\n      "expected": "4.0.0",\n      "description": "transitive dep js-tokens version resolved correctly"\n    },\n    {\n      "check": "dependency_version",\n      "package": "@testing-library/dom",\n      "expected": "9.3.4",\n      "description": "transitive dep @testing-library/dom version resolved correctly"\n    }\n  ]\n}\n